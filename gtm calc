        if (d.summary)   html += `<p>${d.summary}</p>\n`;
        if (d.relevance) html += `<p>→ ${d.relevance}</p>\n`;
      } else if (id === 'market_leaders') {
        html += `<p><strong>${d.company}</strong> [${d.cat||''}] — ${d.date||''}</p>\n`;
        if (d.news)   html += `<p>${d.news}</p>\n`;
        if (d.impact) html += `<p>→ ${d.impact}</p>\n`;
        if (d.url)    html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'whales') {
        html += `<p><strong>${d.company}</strong> [${d.type||''}, ${d.priority||''}] — ${d.date||''}</p>\n`;
        if (d.desc) html += `<p>${d.desc}</p>\n`;
        if (d.url)  html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'competition') {
        html += `<p><strong>${d.company}</strong> [${d.type||''}, Threat: ${d.threat||''}] — ${d.date||''}</p>\n`;
        if (d.news)  html += `<p>${d.news}</p>\n`;
        if (d.notes) html += `<p>→ ${d.notes}</p>\n`;
        if (d.url)   html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'customer_signals') {
        html += `<p><strong>${d.company}</strong> [${d.type||''}, Fit: ${d.fit||''}] — ${d.date||''}</p>\n`;
        if (d.signal) html += `<p>${d.signal}</p>\n`;
        if (d.url)    html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'manda') {
        html += `<p><strong>${d.company}</strong> — ${d.event||''} ${d.amount||''} — ${d.date||''}</p>\n`;
        if (d.parties)   html += `<p>${d.parties}</p>\n`;
        if (d.relevance) html += `<p>→ ${d.relevance}</p>\n`;
        if (d.url)       html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'trends') {
        html += `<p><strong>${d.trend}</strong> [${d.traj||''}]</p>\n`;
        if (d.dev)    html += `<p>${d.dev}</p>\n`;
        if (d.impact) html += `<p>→ ${d.impact}</p>\n`;
        if (d.url)    html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      } else if (id === 'blind_spots') {
        html += `<p><strong>${i+1}. ${d.gap}</strong></p>\n`;
        if (d.signal) html += `<p>${d.signal}</p>\n`;
        if (d.action) html += `<p>→ ${d.action}</p>\n`;
        if (d.url)    html += `<p><a href="${d.url}">${d.src}</a></p>\n`;
      }
      html += '<hr>\n';
    });
  });
  return html;
}

document.getElementById('export-gdocs-btn').addEventListener('click', () => {
  const issueTitle = `DualBird Market Intelligence — Issue #${ISSUE} — ${TODAY}`;
