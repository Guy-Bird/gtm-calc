<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DualBird · Market Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:         #111827;
    --bg2:        #1A2437;
    --panel:      rgba(26, 36, 55, 0.85);
    --border:     #2A3A52;
    --border2:    #3B5070;
    --text:       #D1DCF0;
    --text2:      #8BA3C4;
    --text3:      #556882;
    --white:      #F0F6FF;
    --blue:       #4F8EF7;
    --cyan:       #18CFEE;
    --cyan2:      #06B6D4;
    --green:      #22D3A0;
    --orange:     #FBBF24;
    --red:        #F87171;
    --purple:     #A78BFA;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Ambient glow background ── */
  body::before {
    content: '';
    position: fixed;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(79,142,247,0.18) 0%, rgba(24,207,238,0.08) 45%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.02) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
    padding: 0 24px 100px;
  }

  /* ── Topbar ── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }
  .topbar-logo {
    height: 28px;
    width: auto;
    flex-shrink: 0;
    /* logo has black bg so we show it on a dark pill */
    border-radius: 6px;
    background: #000;
    padding: 3px 8px;
  }
  .topbar-sep   { color: var(--border2); font-weight: 300; }
  .topbar-sub   { color: var(--text2); font-size: 13px; font-weight: 400; }
  .topbar-meta  { margin-left: auto; display: flex; gap: 16px; align-items: center; }
  .issue-tag {
    font-family: 'Inter', monospace; font-size: 11px;
    color: var(--cyan); font-weight: 600;
    background: rgba(0,209,255,0.08);
    border: 1px solid rgba(0,209,255,0.2);
    padding: 3px 10px; border-radius: 20px;
  }
  .date-tag { font-size: 12px; color: var(--text2); font-weight: 400; }

  /* ── Hero ── */
  .hero { margin-bottom: 40px; }
  .eyebrow {
    font-size: 11px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 16px;
    display: flex; align-items: center; gap: 10px;
  }
  .eyebrow-line {
    width: 24px; height: 1px;
    background: linear-gradient(90deg, var(--cyan), transparent);
    display: inline-block;
  }
  h1 {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--white);
    letter-spacing: -1px;
    margin: 0 0 14px;
  }
  h1 em {
    font-style: normal;
    background: linear-gradient(135deg, #3B82F6, #00D1FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    color: var(--text2); font-size: 13px;
    font-weight: 400; margin: 0 0 32px;
    line-height: 1.6;
  }

  /* ── Generate button ── */
  #gen-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 13px 28px;
    background: linear-gradient(135deg, #2563EB 0%, #0EA5E9 100%);
    border: none; border-radius: 10px; color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 13px; font-weight: 600;
    cursor: pointer; letter-spacing: -0.1px;
    box-shadow: 0 4px 24px rgba(37,99,235,0.4), 0 0 0 1px rgba(255,255,255,0.05) inset;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
    position: relative;
    overflow: hidden;
  }
  #gen-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  #gen-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 32px rgba(37,99,235,0.5), 0 0 0 1px rgba(255,255,255,0.08) inset; }
  #gen-btn:hover::before { opacity: 1; }
  #gen-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-sub { opacity: 0.6; font-weight: 400; font-size: 11px; }

  /* ── Last generated ── */
  #last-gen { margin-top: 14px; display: none; align-items: center; gap: 8px; }
  #last-gen.visible { display: flex; }
  .dot-green {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .last-gen-text { font-size: 12px; color: var(--text2); font-weight: 400; }

  /* ── Progress ── */
  #progress { display: none; margin-bottom: 32px; }
  #progress.visible { display: block; }
  .prog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .prog-label  { font-size: 12px; color: var(--cyan); font-weight: 500; }
  .prog-count  { font-size: 12px; color: var(--text2); font-weight: 400; }
  .prog-track  {
    height: 2px; background: var(--border); border-radius: 2px; overflow: hidden;
    margin-bottom: 14px;
  }
  .prog-fill   {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #3B82F6, #00D1FF);
    border-radius: 2px; transition: width 0.5s ease;
  }
  .prog-pills  { display: flex; gap: 4px; flex-wrap: wrap; }
  .pill {
    font-size: 10px; font-weight: 500;
    padding: 3px 9px; border-radius: 20px;
    background: rgba(30,41,59,0.6); color: var(--text2);
    border: 1px solid var(--border);
    transition: all 0.3s;
    letter-spacing: 0.1px;
  }
  .pill.loading { background: rgba(0,209,255,0.08); color: var(--cyan); border-color: rgba(0,209,255,0.25); }
  .pill.done    { background: rgba(16,185,129,0.08); color: var(--green);  border-color: rgba(16,185,129,0.25); }
  .pill.error   { background: rgba(239,68,68,0.08);  color: var(--red);    border-color: rgba(239,68,68,0.25); }

  /* ── Section cards ── */
  #sections { display: none; }
  #sections.visible { display: block; }

  .sec-card {
    background: rgba(15,23,42,0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 6px;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .sec-card:hover { border-color: var(--border2); }
  .sec-card.loading { border-color: rgba(0,209,255,0.2); box-shadow: 0 0 20px rgba(0,209,255,0.04); }
  .sec-card.error   { border-color: rgba(239,68,68,0.2); }
  .sec-card.done    { border-color: var(--border); }

  .sec-header {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px;
    cursor: pointer;
    user-select: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }
  .sec-header:hover { background: rgba(255,255,255,0.02); }
  .sec-header.open { border-bottom-color: var(--border); }

  .sec-icon   { font-size: 15px; flex-shrink: 0; }
  .sec-label  { font-weight: 600; font-size: 13px; color: var(--white); letter-spacing: -0.2px; transition: color 0.3s; }
  .sec-label.loading { color: var(--cyan); }
  .sec-label.error   { color: var(--red); }

  .sec-status { font-size: 11px; color: var(--text2); font-weight: 400; }
  .sec-status.error { color: var(--red); }
  .sec-desc   { font-size: 11px; color: var(--text3); margin-left: 2px; display: none; }
  @media (min-width: 600px) { .sec-desc { display: inline; } }

  .search-label {
    font-size: 11px; color: var(--cyan); font-weight: 500;
    display: none; align-items: center; gap: 5px;
  }
  .spin-icon { display: inline-block; animation: spin 1.2s linear infinite; }

  .sec-right  { margin-left: auto; display: flex; align-items: center; gap: 10px; }
  .dot-status { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .dot-status.done    { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .dot-status.loading { background: var(--cyan);  animation: pulse-dot 1s ease-in-out infinite; }
  .dot-status.error   { background: var(--red); }
  .chevron {
    color: var(--text3); font-size: 10px;
    display: inline-block; transition: transform 0.25s;
  }
  .chevron.open { transform: rotate(180deg); }

  .sec-body { padding: 0 18px; }

  .sec-error-bar {
    padding: 10px 18px 12px;
    font-size: 11px; color: var(--red); font-weight: 400;
    background: rgba(239,68,68,0.04);
    border-top: 1px solid rgba(239,68,68,0.12);
  }

  /* ── Items ── */
  .item {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .item:last-of-type { border-bottom: none; }

  .item-row {
    display: flex; align-items: flex-start; gap: 8px;
    flex-wrap: wrap; margin-bottom: 6px;
  }
  .item-title {
    font-size: 13.5px; color: var(--white); font-weight: 600;
    line-height: 1.45; flex: 1; min-width: 160px; letter-spacing: -0.2px;
  }
  .item-body {
    font-size: 13px; color: var(--text);
    line-height: 1.7; margin-top: 6px; font-weight: 400;
  }
  .item-rel {
    font-size: 12px; color: var(--cyan); font-weight: 500;
    margin-top: 8px; line-height: 1.55;
    padding-left: 10px;
    border-left: 2px solid rgba(0,209,255,0.3);
  }
  .item-date {
    font-size: 11px; color: var(--text2); font-weight: 400;
    white-space: nowrap; flex-shrink: 0; margin-left: auto; padding-top: 2px;
  }
  .item-num {
    font-size: 11px; color: var(--orange); font-weight: 700;
    min-width: 22px; flex-shrink: 0; padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .item-amount {
    font-size: 13px; color: var(--green); font-weight: 700;
    letter-spacing: -0.2px;
  }
  .src-wrap { margin-top: 10px; }

  a.src-link {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11px; color: var(--cyan); font-weight: 500;
    background: rgba(0,209,255,0.06);
    border: 1px solid rgba(0,209,255,0.15);
    padding: 4px 10px 4px 8px; border-radius: 6px;
    text-decoration: none;
    max-width: 380px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }
  a.src-link:hover { background: rgba(0,209,255,0.12); border-color: rgba(0,209,255,0.3); }
  span.src-plain { font-size: 11px; color: var(--text2); font-weight: 400; }

  /* ── Badges ── */
  .badge {
    display: inline-block;
    font-size: 10px; font-weight: 600;
    padding: 2px 8px; border-radius: 20px;
    letter-spacing: 0.2px; white-space: nowrap;
  }

  /* ── Empty state ── */
  #empty { text-align: center; padding: 80px 20px; color: var(--text2); }
  #empty.hidden { display: none; }
  .empty-icon  { font-size: 44px; margin-bottom: 20px; opacity: 0.25; }
  .empty-title {
    font-size: 20px; font-weight: 700; color: var(--white);
    letter-spacing: -0.5px; margin-bottom: 10px;
  }
  .empty-desc  { font-size: 14px; max-width: 440px; margin: 0 auto; line-height: 1.8; color: var(--text2); }

  /* ── Done banner ── */
  #done-banner {
    display: none; margin-top: 24px; padding: 14px 18px;
    background: rgba(16,185,129,0.06);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 10px;
    align-items: center; gap: 10px;
  }
  #done-banner.visible { display: flex; }
  .done-label { font-size: 13px; color: var(--green); font-weight: 600; }
  .done-time  { font-size: 12px; color: var(--text2); font-weight: 400; margin-left: 4px; }
  #refresh-btn {
    margin-left: auto; padding: 6px 14px;
    background: transparent;
    border: 1px solid var(--border2); border-radius: 7px;
    color: var(--text2); font-size: 12px;
    font-family: 'Inter', sans-serif; font-weight: 500;
    cursor: pointer; transition: border-color 0.15s, color 0.15s;
  }
  #refresh-btn:hover { border-color: var(--cyan); color: var(--white); }

  /* ── Footer ── */
  .footer {
    margin-top: 48px; padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 6px; align-items: center;
  }
  .footer span { font-size: 11px; color: var(--text3); font-weight: 400; }

  /* Export button */
  #export-wrap { margin-top: 16px; display: none; }
  #export-wrap.visible { display: block; }
  .export-bar {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    padding: 16px 20px;
    background: rgba(26,36,55,0.7);
    border: 1px solid var(--border2);
    border-radius: 12px;
  }
  .export-bar-title { font-size: 13px; font-weight: 600; color: var(--white); flex: 1; }
  .export-bar-sub   { font-size: 12px; color: var(--text2); margin-top: 2px; }
  .export-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 8px; border: none;
    font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .export-btn.gdocs {
    background: linear-gradient(135deg, #1a73e8, #0d62d0);
    color: #fff;
    box-shadow: 0 2px 12px rgba(26,115,232,0.4);
  }
  .export-btn.gdocs:hover { transform: translateY(-1px); box-shadow: 0 4px 18px rgba(26,115,232,0.55); }
  .export-btn.html {
    background: transparent;
    color: var(--text2);
    border: 1px solid var(--border2);
  }
  .export-btn.html:hover { border-color: var(--cyan); color: var(--white); }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

  /* ── Animations ── */
  @keyframes spin      { from { transform: rotate(0deg) }   to { transform: rotate(360deg) } }
  @keyframes pulse-dot { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.85); } }
</style>
</head>
<body>
<div class="wrap">

  <!-- Topbar -->
  <div class="topbar">
    <img src="data:image/png;base64," alt="DualBird" class="topbar-logo"/>
    <span class="topbar-sep">/</span>
    <span class="topbar-sub">Market Intelligence</span>
    <div class="topbar-meta">
      <span class="issue-tag" id="issue-num"></span>
      <span class="date-tag"  id="today-date"></span>
    </div>
  </div>

  <!-- Hero -->
  <div class="hero">
    <div class="eyebrow">
      <span class="eyebrow-line"></span>AI-Powered Weekly Briefing
    </div>
    <h1>Data & AI <em>Infrastructure</em><br>Intelligence Report</h1>
    <p class="hero-sub">9 intelligence sections · live web research · real sources · built for DualBird GTM</p>

    <button id="gen-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <span id="btn-text">Generate Intelligence Report</span>
      <span class="btn-sub">· live web search</span>
    </button>

    <div id="last-gen">
      <div class="dot-green"></div>
      <span class="last-gen-text" id="last-gen-text"></span>
    </div>
  </div>

  <!-- Progress -->
  <div id="progress">
    <div class="prog-header">
      <span class="prog-label">Researching 9 sections via live web search…</span>
      <span class="prog-count" id="prog-count">0/9 complete</span>
    </div>
    <div class="prog-track"><div class="prog-fill" id="prog-fill"></div></div>
    <div class="prog-pills" id="prog-pills"></div>
  </div>

  <!-- Empty state -->
  <div id="empty">
    <div class="empty-icon">⚡</div>
    <div class="empty-title">Ready to generate</div>
    <p class="empty-desc">Click <strong style="color:var(--white)">Generate Intelligence Report</strong> to run live web searches across all 9 sections — publications, whale accounts, competitors, M&A, trends, and more.</p>
  </div>

  <!-- Section cards -->
  <div id="sections"></div>

  <!-- Done banner -->
  <div id="done-banner">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <span class="done-label">Report complete</span>
    <span class="done-time" id="done-time"></span>
    <button id="refresh-btn">↻ Refresh</button>
  </div>

  <!-- Export bar -->
  <div id="export-wrap">
    <div class="export-bar">
      <div>
        <div class="export-bar-title">📋 Export this report</div>
        <div class="export-bar-sub">Save to Google Docs or download as HTML</div>
      </div>
      <button class="export-btn gdocs" id="export-gdocs-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Open in Google Docs
      </button>
      <button class="export-btn html" id="export-html-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download HTML
      </button>
    </div>
  </div>

  <div class="footer">
    <span id="footer-date"></span>
    <span>Verify all sources before external use</span>
  </div>
</div>

<script>
const ISSUE = Math.max(1, Math.ceil((new Date() - new Date('2026-03-08')) / (7*86400000)) + 1);
const TODAY = new Date().toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});

document.getElementById('issue-num').textContent  = `Issue #${ISSUE}`;
document.getElementById('today-date').textContent = TODAY;
document.getElementById('footer-date').textContent = `DualBird Market Intelligence · AI-Powered · ${TODAY}`;

const SECTIONS = [
  {id:'tldr',            icon:'⚡', label:'TL;DR',            desc:'Top 5 signal developments this week'},
  {id:'publications',    icon:'📰', label:'Publications',     desc:'Technical articles, blogs & case studies'},
  {id:'market_leaders',  icon:'🏢', label:'Market Leaders',   desc:'AWS, Databricks, Snowflake & major players'},
  {id:'whales',          icon:'🐳', label:'Whale Accounts',   desc:'Named enterprise targets showing signals'},
  {id:'competition',     icon:'⚔️', label:'Competition',      desc:'Direct competitors & emerging threats'},
  {id:'customer_signals',icon:'📡', label:'Customer Signals', desc:'ICP buying intent and pain signals'},
  {id:'manda',           icon:'💰', label:'M&A & Funding',    desc:'Ecosystem deals, rounds & consolidation'},
  {id:'trends',          icon:'📈', label:'Trends',           desc:'Macro direction of travel'},
  {id:'blind_spots',     icon:'🔍', label:'Blind Spots',      desc:'What might we be missing?'},
];

const DB_CONTEXT = `DualBird is an FPGA-based infrastructure acceleration company that speeds up Apache Spark and Apache Iceberg workloads on AWS by 10-30x while reducing cloud costs by 50-90%, with zero integration or migration required. Backed by Bessemer, Lightspeed, and ICON. Targets enterprises running large-scale Spark/Iceberg on AWS in finance, media, and tech.`;

const JSON_RULES = `OUTPUT FORMAT — STRICT:
Your entire response must be ONLY a valid JSON array starting with [ and ending with ].
Do NOT write any text, explanation, or commentary before or after the JSON.
Do NOT say "I need to search" or narrate your process — just output the JSON array.
Do NOT use markdown code fences or backticks.
All string values: plain text only. No <cite> tags, no HTML, no XML inside values.
URLs must be real https:// links from your search results.
If you cannot find real data for a field, use a short placeholder string — never skip the field.`;

const PROMPTS = {
  tldr: `You are a B2B market intelligence analyst. ${DB_CONTEXT} Today is ${TODAY}.

Search the web for the 5 most important developments THIS WEEK relevant to DualBird. Focus on: Apache Spark/Iceberg news, AWS analytics, Databricks/Snowflake updates, enterprise data infrastructure, FPGA/hardware acceleration.

