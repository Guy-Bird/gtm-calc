function badge(v) {
  if (!v) return '';
  const s = BADGE_STYLES[v] || {bg:'rgba(71,85,105,0.4)', color:'#94A3B8', border:'rgba(71,85,105,0.4)'};
  return `<span class="badge" style="background:${s.bg};color:${s.color};border:1px solid ${s.border||s.bg}">${esc(v)}</span>`;
}

function srcLink(name, url) {
  if (!name && !url) return '';
  if (!url || !url.startsWith('http')) {
    return `<span class="src-plain">${esc(name||'')}</span>`;
  }
  return `<a class="src-link" href="${esc(url)}" target="_blank" rel="noopener noreferrer">
    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;opacity:0.6">
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
      <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
    </svg>
    ${esc(name||url)}
  </a>`;
}

function esc(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderItems(id, items) {
  if (!items || !items.length) return '';
  const rows = items.map((d, i) => {
    let html = '<div class="item">';
    if (id === 'tldr') {
      html += `<div class="item-row"><span class="item-num">0${i+1}</span><span class="item-title">${esc(d.point)}</span></div>`;
      if (d.relevance) html += `<div class="item-rel">→ ${esc(d.relevance)}</div>`;
    } else if (id === 'publications') {
      html += `<div class="item-row"><span class="item-title">${esc(d.title)}</span>${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.summary)   html += `<div class="item-body">${esc(d.summary)}</div>`;
      if (d.relevance) html += `<div class="item-rel">→ ${esc(d.relevance)}</div>`;
    } else if (id === 'market_leaders') {
      html += `<div class="item-row"><span class="item-title">${esc(d.company)}</span>${badge(d.cat)}${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.news)   html += `<div class="item-body">${esc(d.news)}</div>`;
      if (d.impact) html += `<div class="item-rel">→ ${esc(d.impact)}</div>`;
    } else if (id === 'whales') {
      html += `<div class="item-row"><span class="item-title">${esc(d.company)}</span>${badge(d.type)}${badge(d.priority)}${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.desc) html += `<div class="item-body">${esc(d.desc)}</div>`;
    } else if (id === 'competition') {
      html += `<div class="item-row"><span class="item-title">${esc(d.company)}</span>${badge(d.type)}${badge(d.threat)}${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.news)  html += `<div class="item-body">${esc(d.news)}</div>`;
      if (d.notes) html += `<div class="item-rel">→ ${esc(d.notes)}</div>`;
    } else if (id === 'customer_signals') {
      html += `<div class="item-row"><span class="item-title">${esc(d.company)}</span>${badge(d.type)}${badge(d.fit)}${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.signal) html += `<div class="item-body">${esc(d.signal)}</div>`;
    } else if (id === 'manda') {
      html += `<div class="item-row"><span class="item-title">${esc(d.company)}</span>${badge(d.event)}${d.amount?`<span class="item-amount">${esc(d.amount)}</span>`:''}${d.date?`<span class="item-date">${esc(d.date)}</span>`:''}</div>`;
      if (d.parties)   html += `<div class="item-body">${esc(d.parties)}</div>`;
      if (d.relevance) html += `<div class="item-rel">→ ${esc(d.relevance)}</div>`;
    } else if (id === 'trends') {
      html += `<div class="item-row"><span class="item-title">${esc(d.trend)}</span>${badge(d.traj)}</div>`;
      if (d.dev)    html += `<div class="item-body">${esc(d.dev)}</div>`;
      if (d.impact) html += `<div class="item-rel">→ ${esc(d.impact)}</div>`;
    } else if (id === 'blind_spots') {
      html += `<div class="item-row"><span class="item-num">0${i+1}</span><span class="item-title">${esc(d.gap)}</span></div>`;
      if (d.signal) html += `<div class="item-body">${esc(d.signal)}</div>`;
      if (d.action) html += `<div class="item-rel">→ ${esc(d.action)}</div>`;
    }
    html += `<div class="src-wrap">${srcLink(d.src, d.url)}</div>`;
    html += '</div>';
    return html;
  });
  return rows.join('\n');
}

