async function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// Clean raw text into parseable JSON
function extractJSON(text) {
  let raw = text
    .replace(/^```json\s*/im, '')
    .replace(/^```\s*/im, '')
    .replace(/```\s*$/gm, '')
    .replace(/<cite[^>]*>[\s\S]*?<\/cite>/gi, '')
    .replace(/<[^>]+>/g, '')
    .trim();

  const start = raw.indexOf('[');
  const end   = raw.lastIndexOf(']');
  if (start === -1 || end === -1) return null;

  let jsonStr = raw.slice(start, end + 1);

  // Attempt 1: direct parse
  try { return JSON.parse(jsonStr); } catch(e) {}

  // Attempt 2: strip control chars then parse
  try {
    const s = jsonStr
      .replace(/[\r\n\t]+/g, ' ')
      .replace(/,\s*([\]}])/g, '$1');
    return JSON.parse(s);
  } catch(e) {}

  // Attempt 3: extract objects one by one
  try {
    const objects = [];
    const objRegex = /\{[^{}]*(?:\{[^{}]*\}[^{}]*)?\}/g;
    let m;
    while ((m = objRegex.exec(jsonStr)) !== null) {
      try { objects.push(JSON.parse(m[0])); } catch(e) {}
    }
    if (objects.length > 0) return objects;
  } catch(e) {}

  return null;
}

async function apiRequest(messages, useSearch = true) {
  const body = {
    model: 'claude-sonnet-4-6',
    max_tokens: 1500,
    messages,
  };
  if (useSearch) body.tools = [{ type: 'web_search_20250305', name: 'web_search' }];
  return fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
}

function getText(data) {
  return (data.content || [])
    .filter(b => b.type === 'text')
    .map(b => b.text)
    .join('\n');
}

async function fetchSection(id, attempt = 0) {
  // On retry (attempt > 0), use a two-turn conversation:
  // first turn = original prompt, second turn = strict JSON-only demand
  let messages;
  if (attempt === 0) {
    messages = [{ role: 'user', content: PROMPTS[id] }];
  } else {
    // Re-send original prompt then demand JSON output explicitly
    messages = [
      { role: 'user', content: PROMPTS[id] },
      { role: 'assistant', content: 'I need to search for this information.' },
      { role: 'user', content: 'Do not explain anything. Output ONLY the raw JSON array now, starting with [ and ending with ]. No other text.' }
    ];
  }

  const res = await apiRequest(messages, attempt === 0);

  if (res.status === 429 && attempt < 3) {
    const wait = (attempt + 1) * 30000;
    console.warn(`[${id}] 429 rate limit, retrying in ${wait/1000}s (attempt ${attempt+1}/3)`);
    await sleep(wait);
    return fetchSection(id, attempt + 1);
  }

  if (!res.ok) {
    const body = await res.text();
    throw new Error(`HTTP ${res.status}: ${body.slice(0, 250)}`);
  }

  const data = await res.json();
  const allText = getText(data);

  if (!allText.trim()) {
    throw new Error(`No text in response. stop_reason=${data.stop_reason}`);
  }

  const result = extractJSON(allText);
  if (result && result.length > 0) return result;

  if (attempt < 2) {
    console.warn(`[${id}] No JSON found, retrying with stricter follow-up (attempt ${attempt + 1})`);
    await sleep(2000);
    return fetchSection(id, attempt + 1);
  }

  throw new Error(`No JSON array after ${attempt + 1} attempts. Preview: ${allText.slice(0, 200)}`);
}

async function generate() {
  if (generating) return;
  generating = true;
  sectionData = {}; statuses = {}; errors = {}; doneCount = 0;

  document.getElementById('gen-btn').disabled = true;
  document.getElementById('btn-text').textContent = 'Generating…';
  document.getElementById('empty').classList.add('hidden');
  document.getElementById('done-banner').classList.remove('visible');
  document.getElementById('export-wrap').classList.remove('visible');
  document.getElementById('last-gen').classList.remove('visible');
  document.getElementById('progress').classList.add('visible');
  document.getElementById('sections').classList.add('visible');

  buildPills();
  buildSectionCards();

  // Run in batches of 3 to avoid hitting the concurrency rate limit
  async function runSection(s) {
    statuses[s.id] = 'loading';
    setCardStatus(s.id, 'loading');
    updateProgress();
    try {
      const result = await fetchSection(s.id);
      sectionData[s.id] = result;
      statuses[s.id] = 'done';
      setCardStatus(s.id, 'done');
      fillSectionBody(s.id);
    } catch(e) {
      console.error(`[${s.id}]`, e);
      errors[s.id] = e.message;
      statuses[s.id] = 'error';
      setCardStatus(s.id, 'error', e.message);
    }
    updateProgress();
  }

  // Run fully sequentially with a small gap — avoids all concurrency and 5-hour rate limits
  for (const s of SECTIONS) {
    await runSection(s);
    await sleep(1500); // 1.5s pause between requests
  }

  generating = false;
  document.getElementById('gen-btn').disabled = false;
  document.getElementById('btn-text').textContent = 'Regenerate Report';
  document.getElementById('progress').classList.remove('visible');

  const time = new Date().toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
  document.getElementById('last-gen-text').textContent = `Generated ${time} · sources via live search`;
  document.getElementById('last-gen').classList.add('visible');

  document.getElementById('done-time').textContent = `All sections researched · ${time}`;
  document.getElementById('done-banner').classList.add('visible');
  document.getElementById('export-wrap').classList.add('visible');
}

document.getElementById('gen-btn').addEventListener('click', generate);
document.getElementById('refresh-btn').addEventListener('click', generate);

