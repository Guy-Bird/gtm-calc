function updateProgress() {
  const done  = Object.values(statuses).filter(s => s === 'done').length;
  const total = SECTIONS.length;
  document.getElementById('prog-count').textContent = `${done}/${total} complete`;
  document.getElementById('prog-fill').style.width  = `${Math.round(done/total*100)}%`;

  SECTIONS.forEach(s => {
    const pill = document.getElementById(`pill-${s.id}`);
    if (!pill) return;
    const st = statuses[s.id] || 'pending';
    pill.className = `pill ${st}`;
    const prefix = st==='done'?'✓ ': st==='loading'?'◌ ': st==='error'?'✕ ': '· ';
    pill.textContent = `${prefix}${s.label}`;
  });
}

function setCardStatus(id, status, err) {
  const card   = document.getElementById(`card-${id}`);
  const label  = document.getElementById(`label-${id}`);
  const dot    = document.getElementById(`dot-${id}`);
  const stEl   = document.getElementById(`status-${id}`);
  const searchEl = document.getElementById(`search-${id}`);
  const errBar = document.getElementById(`errbar-${id}`);
  if (!card) return;

  card.className  = `sec-card ${status}`;
  label.className = `sec-label ${status}`;

  // dot
  dot.className  = `dot-status ${status}`;
  dot.style.display = (status === 'pending') ? 'none' : 'block';

  // status text
  if (status === 'loading') {
    stEl.textContent   = '';
    searchEl.style.display = 'flex';
  } else if (status === 'done') {
    const count = (sectionData[id] || []).length;
    stEl.textContent   = `${count} items`;
    stEl.className     = 'sec-status';
    searchEl.style.display = 'none';
  } else if (status === 'error') {
    stEl.textContent   = 'error — see below';
    stEl.className     = 'sec-status error';
    searchEl.style.display = 'none';
  }

  if (err && errBar) {
    errBar.textContent    = `✕ ${err}`;
    errBar.style.display  = 'block';
  }
}

