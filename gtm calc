  // Full HTML document that Google Docs can import cleanly
  const fullDoc = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${issueTitle}</title></head><body>
<h1>${issueTitle}</h1>
<p><em>AI-generated market intelligence for DualBird GTM. Verify all sources before external use.</em></p>
<hr>
${body}
</body></html>`;

  // Create a Blob and open it — user can then File > Open in Google Docs
  const blob = new Blob([fullDoc], { type: 'text/html' });
  const url  = URL.createObjectURL(blob);

  // Download the file — user uploads it to Google Drive, then opens with Google Docs
  const a = document.createElement('a');
  a.href     = url;
  a.download = `DualBird-Intel-Issue-${ISSUE}-${TODAY.replace(/,/g,'').replace(/ /g,'-')}.html`;
  a.click();
  URL.revokeObjectURL(url);

  // Also open Google Drive upload page
  setTimeout(() => window.open('https://drive.google.com/drive/my-drive', '_blank'), 600);
});

